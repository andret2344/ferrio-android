<?xml version="1.0" encoding="utf-8"?>
<resources>

	<style name="RoundedIconShape">
		<item name="cornerSize">48dp</item>
		<item name="cornerFamily">rounded</item>
	</style>

	<style name="Widget.UnusualHoliday.GoogleButton" parent="Widget.Material3.Button.OutlinedButton">
		<item name="android:textColor">@color/button_text</item>
		<item name="strokeColor">@color/button_border</item>
		<item name="iconTint">@null</item>
		<item name="iconPadding">8dp</item>
	</style>

	<style name="Widget.UnusualHoliday.SecondaryButton" parent="Widget.Material3.Button.TextButton">
		<item name="android:background">@color/button_background</item>
		<item name="android:textColor">@color/button_text</item>
	</style>

	<style name="Widget.UnusualHoliday.TextButton.Report" parent="Widget.Material3.Button.TextButton.Icon">
		<item name="iconTint">@color/report_text</item>
		<item name="android:textColor">@color/report_text</item>
	</style>

	<style name="Widget.UnusualHoliday.ProgressBar.White" parent="Widget.Material3.CircularProgressIndicator">
		<item name="indicatorColor">@android:color/white</item>
	</style>

	<style name="DialogSlideAnimation">
		<item name="android:windowEnterAnimation">@anim/slide_up</item>
		<item name="android:windowExitAnimation">@anim/slide_down</item>
	</style>

</resources>
