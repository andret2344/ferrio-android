<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:fitsSystemWindows="true">

	<com.google.android.material.appbar.MaterialToolbar
		android:id="@+id/activity_holiday_toolbar"
		android:layout_width="match_parent"
		android:layout_height="?attr/actionBarSize"
		android:paddingStart="6dp"
		android:paddingEnd="16dp"
		app:contentInsetStartWithNavigation="0dp"
		app:layout_constraintTop_toTopOf="parent"
		app:title="@string/app_name" />

	<com.google.android.material.card.MaterialCardView
		android:id="@+id/card"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_margin="@dimen/activity_holiday_card_margin"
		app:cardElevation="@dimen/activity_holiday_card_elevation"
		app:layout_constrainedHeight="true"
		app:layout_constraintBottom_toTopOf="@id/activity_holiday_adview_bottom"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@id/activity_holiday_toolbar"
		app:layout_constraintVertical_bias="0">

		<RelativeLayout
			android:layout_width="match_parent"
			android:layout_height="match_parent">

			<com.google.android.material.button.MaterialButton
				android:id="@+id/activity_holiday_button_favorite"
				style="@style/Widget.Material3.Button.IconButton"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_alignParentTop="true"
				android:layout_alignParentEnd="true"
				android:layout_margin="4dp"
				android:scaleX="1.5"
				android:scaleY="1.5"
				android:visibility="gone"
				app:icon="@drawable/baseline_star_24" />
		</RelativeLayout>

		<com.google.android.material.progressindicator.CircularProgressIndicator
			android:id="@+id/activity_holiday_progress"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_gravity="center"
			android:layout_margin="48dp"
			android:indeterminate="true" />

		<androidx.constraintlayout.widget.ConstraintLayout
			android:id="@+id/activity_holiday_content"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:paddingHorizontal="@dimen/activity_holiday_content_padding_horizontal"
			android:visibility="gone">

			<ImageView
				android:id="@+id/activity_holiday_image"
				android:layout_width="match_parent"
				android:layout_height="194dp"
				android:contentDescription="@string/content_description_image"
				android:scaleType="centerCrop"
				android:visibility="gone"
				app:layout_constraintTop_toTopOf="parent" />

			<TextView
				android:id="@+id/activity_holiday_name"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:gravity="center"
				android:paddingHorizontal="@dimen/activity_holiday_name_padding_horizontal"
				android:paddingTop="@dimen/activity_holiday_name_padding_top"
				android:paddingBottom="@dimen/activity_holiday_name_padding_bottom"
				android:textAppearance="?attr/textAppearanceTitleLarge"
				android:textColor="?android:attr/textColorPrimary"
				android:textSize="@dimen/activity_holiday_name"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintTop_toBottomOf="@id/activity_holiday_image" />

			<TextView
				android:id="@+id/activity_holiday_date"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:gravity="center"
				android:paddingHorizontal="@dimen/activity_holiday_date_padding_horizontal"
				android:paddingBottom="@dimen/activity_holiday_date_padding_bottom"
				android:textAppearance="?attr/textAppearanceBodyMedium"
				android:textColor="?android:attr/textColorSecondary"
				android:textSize="@dimen/activity_holiday_description"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintTop_toBottomOf="@id/activity_holiday_name" />

			<ScrollView
				android:id="@+id/activity_holiday_scroll"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_marginTop="@dimen/activity_holiday_scroll_margin_top"
				android:fadingEdgeLength="@dimen/activity_holiday_scroll_fading_edge"
				android:requiresFadingEdge="vertical"
				app:layout_constrainedHeight="true"
				app:layout_constraintBottom_toTopOf="@id/activity_holiday_buttons"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintTop_toBottomOf="@id/activity_holiday_date"
				app:layout_constraintVertical_bias="0"
				app:layout_constraintVertical_chainStyle="packed">

				<LinearLayout
					android:id="@+id/activity_holiday_description_container"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical" />
			</ScrollView>

			<LinearLayout
				android:id="@+id/activity_holiday_buttons"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:orientation="horizontal"
				android:paddingBottom="@dimen/activity_holiday_buttons_padding_bottom"
				app:layout_constraintBottom_toBottomOf="parent"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintTop_toBottomOf="@id/activity_holiday_scroll">

				<com.google.android.material.button.MaterialButton
					android:id="@+id/activity_holiday_button_report"
					style="@style/Widget.UnusualHoliday.TextButton.Report"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/report"
					app:icon="@drawable/baseline_warning_amber_24" />

				<com.google.android.material.button.MaterialButton
					android:id="@+id/activity_holiday_button_read_more"
					style="?attr/borderlessButtonStyle"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/read_more"
					android:visibility="gone" />
			</LinearLayout>
		</androidx.constraintlayout.widget.ConstraintLayout>
	</com.google.android.material.card.MaterialCardView>

	<com.google.android.gms.ads.AdView
		android:id="@+id/activity_holiday_adview_bottom"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:contentDescription="@string/content_description_ad"
		app:adSize="BANNER"
		app:adUnitId="@string/banner_ad_unit_id"
		app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
