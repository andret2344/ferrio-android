<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/main"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	tools:context=".activity.MissingActivity">

	<com.google.android.material.appbar.MaterialToolbar
		android:id="@+id/activity_missing_toolbar"
		android:layout_width="match_parent"
		android:layout_height="?attr/actionBarSize"
		android:paddingStart="6dp"
		android:paddingEnd="16dp"
		app:contentInsetStartWithNavigation="0dp"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent"
		app:layout_constraintBottom_toTopOf="@id/activity_missing_frame_layout"
		app:title="@string/missing_holiday" />

	<FrameLayout
		android:id="@+id/activity_missing_frame_layout"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		app:layout_constraintTop_toBottomOf="@id/activity_missing_toolbar"
		app:layout_constraintBottom_toTopOf="@id/activity_missing_bottom_navigation" />

	<com.google.android.material.bottomnavigation.BottomNavigationView
		android:id="@+id/activity_missing_bottom_navigation"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		app:layout_constraintTop_toBottomOf="@id/activity_missing_frame_layout"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:menu="@menu/missing" />

</androidx.constraintlayout.widget.ConstraintLayout>
