<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	tools:context=".activity.SuggestionsActivity">

	<com.google.android.material.appbar.MaterialToolbar
		android:id="@+id/activity_suggestions_toolbar"
		android:layout_width="match_parent"
		android:layout_height="?attr/actionBarSize"
		android:paddingStart="6dp"
		android:paddingEnd="16dp"
		app:contentInsetStartWithNavigation="0dp"
		app:layout_constraintBottom_toTopOf="@id/activity_suggestions_tab_layout"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent"
		app:title="@string/my_suggestions" />

	<com.google.android.material.tabs.TabLayout
		android:id="@+id/activity_suggestions_tab_layout"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		app:layout_constraintBottom_toTopOf="@id/activity_suggestions_view_pager"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@id/activity_suggestions_toolbar" />

	<androidx.viewpager2.widget.ViewPager2
		android:id="@+id/activity_suggestions_view_pager"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@id/activity_suggestions_tab_layout" />
</androidx.constraintlayout.widget.ConstraintLayout>
