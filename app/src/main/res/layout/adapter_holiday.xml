<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:layout_gravity="center_vertical"
	android:layout_marginBottom="1dp"
	android:background="@color/background_secondary"
	android:orientation="horizontal"
	android:paddingStart="5dp"
	android:paddingTop="5dp"
	android:paddingEnd="5dp"
	android:paddingBottom="5dp">

	<TextView
		android:id="@+id/adapter_holiday_text_bullet"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:gravity="center_vertical"
		android:padding="5dp"
		android:text="@string/bullet_point"
		android:textColor="@color/foreground_primary"
		android:textSize="@dimen/adapter_holiday_main" />

	<TextView
		android:id="@+id/adapter_holiday_text_holiday"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_toStartOf="@id/adapter_holiday_text_country"
		android:layout_toEndOf="@id/adapter_holiday_text_bullet"
		android:gravity="center_vertical"
		android:paddingTop="5dp"
		android:paddingBottom="5dp"
		android:textColor="@color/foreground_primary"
		android:textSize="@dimen/adapter_holiday_main" />

	<TextView
		android:id="@+id/adapter_holiday_text_country"
		android:layout_width="50dp"
		android:layout_height="wrap_content"
		android:layout_alignTop="@id/adapter_holiday_text_holiday"
		android:layout_alignBottom="@id/adapter_holiday_text_holiday"
		android:layout_alignParentEnd="true"
		android:layout_toStartOf="@id/adapter_holiday_image_more"
		android:gravity="center_vertical|center_horizontal"
		android:padding="5dp"
		android:textColor="@color/foreground_accent"
		android:textSize="@dimen/adapter_holiday_country" />

	<ImageView
		android:id="@+id/adapter_holiday_image_more"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_alignTop="@id/adapter_holiday_text_holiday"
		android:layout_alignBottom="@id/adapter_holiday_text_holiday"
		android:layout_alignParentEnd="true"
		android:contentDescription="@string/content_description_more"
		android:gravity="center_vertical|center_horizontal"
		android:src="@drawable/baseline_chevron_right_48" />

</RelativeLayout>
