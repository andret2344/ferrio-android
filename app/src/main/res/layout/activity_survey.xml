<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical" >

        <TextView
            android:id="@+id/survey_text_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="0"
            android:gravity="center_horizontal"
            android:textSize="@dimen/fragment_month_month_text" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true" >

            <TextView
                android:id="@+id/survey_text_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:text="@string/about_app_text" />
        </ScrollView>

        <RelativeLayout
            android:id="@+id/survey_relative_container"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_gravity="bottom" >

            <EditText
                android:id="@+id/survey_edit_answer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_above="@+id/survey_button_submit"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:lines="10"
                android:maxLines="100"
                android:scrollbars="vertical" >
            </EditText>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_above="@+id/survey_button_submit" >

                <RadioGroup
                    android:id="@+id/survey_radiogroup_answers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="invisible" >
                </RadioGroup>
            </ScrollView>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_above="@+id/survey_button_submit" >

                <LinearLayout
                    android:id="@+id/survey_checkboxgroup_answers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="invisible" >
                </LinearLayout>
            </ScrollView>

            <Button
                android:id="@+id/survey_button_submit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:text="@string/send" />
        </RelativeLayout>
    </LinearLayout>

    <com.google.android.gms.ads.AdView
        android:id="@+id/survey_adview_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        ads:adSize="SMART_BANNER"
        ads:adUnitId="@string/banner_ad_unit_id" />

</RelativeLayout>