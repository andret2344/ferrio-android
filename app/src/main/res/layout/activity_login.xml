<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	tools:context=".activity.LoginActivity">

	<RelativeLayout
		android:id="@+id/activity_login_layout_progress"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="#AA000000"
		android:elevation="4dp"
		android:gravity="center"
		android:visibility="gone">

		<ProgressBar
			android:id="@+id/activity_login_progress"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:indeterminate="true"
			android:indeterminateTintMode="src_atop" />
	</RelativeLayout>

	<ImageView
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:src="@drawable/ic_app_logo"
		android:contentDescription="@string/content_description_icon_main"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintLeft_toLeftOf="parent"
		app:layout_constraintRight_toRightOf="parent"
		app:layout_constraintTop_toTopOf="parent"
		app:layout_constraintVertical_bias="0.3" />

	<androidx.constraintlayout.widget.ConstraintLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintLeft_toLeftOf="parent"
		app:layout_constraintRight_toRightOf="parent"
		app:layout_constraintTop_toTopOf="parent"
		app:layout_constraintVertical_bias="0.8">

		<com.google.android.gms.common.SignInButton
			android:id="@+id/activity_login_sign_in_google"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginStart="50dp"
			android:layout_marginTop="10dp"
			android:layout_marginEnd="50dp"
			app:layout_constraintBottom_toTopOf="@id/activity_login_sign_in_anonymous"
			app:layout_constraintLeft_toLeftOf="parent"
			app:layout_constraintRight_toRightOf="parent"
			app:layout_constraintTop_toTopOf="parent" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/activity_login_sign_in_anonymous"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginStart="50dp"
			android:layout_marginTop="10dp"
			android:layout_marginEnd="50dp"
			android:text="@string/logging_in_anonymously"
			android:textColor="@color/background_primary"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintLeft_toLeftOf="parent"
			app:layout_constraintRight_toRightOf="parent"
			app:layout_constraintTop_toBottomOf="@id/activity_login_sign_in_google" />
	</androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
