<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:id="@+id/fragment_day_relative_main"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/background_primary">

	<androidx.recyclerview.widget.RecyclerView
		android:id="@+id/fragment_day_list_holidays"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="@color/background_primary"
		app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

	<ImageView
		android:id="@+id/fragment_day_image_sad"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:contentDescription="@string/content_description_image_sad_face"
		android:scaleType="centerInside"
		android:src="@drawable/baseline_emoji_sad"
		android:visibility="invisible"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent" />

	<TextView
		android:id="@+id/fragment_day_text_empty"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:gravity="center"
		android:text="@string/no_unusual_holidays"
		android:textColor="@color/foreground_primary"
		android:textSize="@dimen/fragment_day_empty"
		android:visibility="visible"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintVertical_bias="0.1"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@id/fragment_day_image_sad" />

</androidx.constraintlayout.widget.ConstraintLayout>
