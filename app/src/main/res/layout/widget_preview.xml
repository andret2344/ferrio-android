<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@drawable/rounded_widget"
	android:orientation="vertical"
	android:padding="16dp">

	<TextView
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:gravity="center"
		android:text="@string/widget_preview_date"
		android:textColor="@color/on_surface"
		android:textSize="@dimen/widget_text_date_size"
		android:textStyle="bold" />

	<FrameLayout
		android:layout_width="match_parent"
		android:layout_height="1dp"
		android:layout_marginHorizontal="16dp"
		android:layout_marginTop="10dp"
		android:background="@color/outline_variant" />

	<TextView
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="8dp"
		android:text="@string/widget_preview_holidays"
		android:textColor="@color/on_surface"
		android:textSize="@dimen/widget_text_holidays_size" />

</LinearLayout>
