<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/widget_root"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@drawable/rounded_widget_transparent"
	android:orientation="vertical"
	android:padding="16dp">

	<TextView
		android:id="@+id/widget_text_date"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:gravity="center"
		android:shadowColor="@color/widget_transparent_shadow"
		android:shadowDx="1"
		android:shadowDy="1"
		android:shadowRadius="3"
		android:textColor="@color/widget_transparent_text"
		android:textSize="20sp"
		android:textStyle="bold" />

	<FrameLayout
		android:layout_width="match_parent"
		android:layout_height="1dp"
		android:layout_marginHorizontal="16dp"
		android:layout_marginTop="10dp"
		android:background="@color/widget_transparent_divider" />

	<ImageView
		android:id="@+id/widget_image_empty"
		android:layout_width="32dp"
		android:layout_height="32dp"
		android:layout_gravity="center_horizontal"
		android:layout_marginTop="8dp"
		android:contentDescription="@string/content_description_icon_sad"
		android:src="@drawable/baseline_emoji_sad"
		android:tint="@color/widget_transparent_text"
		android:visibility="gone" />

	<TextView
		android:id="@+id/widget_text_holidays"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="8dp"
		android:shadowColor="@color/widget_transparent_shadow"
		android:shadowDx="1"
		android:shadowDy="1"
		android:shadowRadius="3"
		android:textColor="@color/widget_transparent_text"
		android:textSize="14sp" />

	<LinearLayout
		android:id="@+id/widget_layout_login"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:gravity="center"
		android:orientation="vertical"
		android:visibility="gone"
		tools:ignore="UseCompoundDrawables">

		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:gravity="center"
			android:shadowColor="@color/widget_transparent_shadow"
			android:shadowDx="1"
			android:shadowDy="1"
			android:shadowRadius="3"
			android:text="@string/widget_login_required"
			android:textColor="@color/widget_transparent_text"
			android:textSize="14sp" />

		<ImageView
			android:layout_width="48dp"
			android:layout_height="48dp"
			android:layout_marginTop="8dp"
			android:contentDescription="@string/widget_login_required"
			android:src="@drawable/baseline_login_24"
			android:tint="@color/widget_transparent_text" />

	</LinearLayout>

</LinearLayout>
