<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent" >

    <ListView
        android:id="@+id/language_list_languages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/language_text_explaination"
        android:layout_alignParentTop="true"
        android:choiceMode="singleChoice"
        android:descendantFocusability="beforeDescendants"
        android:longClickable="true" >
    </ListView>

    <TextView
        android:id="@+id/language_text_explaination"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/language_adview_bottom"
        android:text="@string/no_languages_explaination" />

    <com.google.android.gms.ads.AdView
        android:id="@+id/language_adview_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        ads:adSize="SMART_BANNER"
        ads:adUnitId="@string/banner_ad_unit_id" />

</RelativeLayout>