<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

	<PreferenceCategory
		android:key="app"
		android:title="@string/preference_category_application">
		<SwitchPreference
			android:defaultValue="false"
			android:disableDependentsState="true"
			android:icon="@drawable/baseline_palette_24"
			android:key="@string/settings_key_theme_colorized"
			android:summary="@string/preference_description_colorized_days"
			android:title="@string/preference_title_colorized_days" />

		<SwitchPreference
			android:defaultValue="false"
			android:icon="@drawable/baseline_add_circle_24"
			android:key="@string/settings_key_usual_holidays"
			android:summary="@string/preference_description_include_usual"
			android:title="@string/preference_title_include_usual" />

		<Preference
			android:icon="@drawable/baseline_edit_calendar_24"
			android:key="@string/settings_key_month_view_mode"
			android:title="@string/preference_title_month_view_mode" />

		<ListPreference
			android:defaultValue="system"
			android:entries="@array/preference_theme_entries"
			android:entryValues="@array/preference_theme_values"
			android:icon="@drawable/baseline_brightness_medium_24"
			android:key="@string/settings_key_app_theme"
			android:summary="%s"
			android:title="@string/app_theme" />

		<Preference
			android:icon="@drawable/baseline_logout_24"
			android:key="@string/settings_key_logout"
			android:title="@string/logout" />
	</PreferenceCategory>

</PreferenceScreen>
