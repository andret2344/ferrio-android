<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory
        android:key="app"
        android:title="@string/pref_category_app">
        <ListPreference
            android:defaultValue="1"
            android:dialogTitle="@string/pref_title_app_theme"
            android:entries="@array/pref_theme_application_list"
            android:entryValues="@array/pref_theme_application_values"
            android:key="@string/settings_key_theme_app"
            android:negativeButtonText="@null"
            android:positiveButtonText="@null"
            android:title="@string/pref_title_app_theme" />

        <SwitchPreference
            android:defaultValue="false"
            android:disableDependentsState="true"
            android:key="@string/settings_key_theme_colorized"
            android:summary="@string/colorized_days_desc"
            android:title="@string/colorized_days" />
        <SwitchPreference
            android:defaultValue="false"
            android:key="@string/settings_key_usual_holidays"
            android:summary="@string/usual_holidays_desc"
            android:title="@string/usual_holidays" />
        <SwitchPreference
            android:defaultValue="true"
            android:key="@string/settings_key_display_shortcuts"
            android:summary="@string/display_shortcuts_desc"
            android:title="@string/display_shortcuts" />
    </PreferenceCategory>
    <PreferenceCategory
        android:key="widgets"
        android:title="@string/pref_category_widget">
        <ListPreference
            android:defaultValue="1"
            android:dialogTitle="@string/pref_title_widgets_theme"
            android:entries="@array/pref_theme_widgets_list"
            android:entryValues="@array/pref_theme_widgets_values"
            android:key="@string/settings_key_theme_widgets"
            android:negativeButtonText="@null"
            android:positiveButtonText="@null"
            android:title="@string/pref_title_widgets_theme" />
    </PreferenceCategory>

</PreferenceScreen>