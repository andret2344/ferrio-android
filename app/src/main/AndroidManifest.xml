<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools">

	<uses-permission android:name="android.permission.INTERNET" />
	<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
	<uses-permission android:name="com.google.android.gms.permission.AD_ID" />
	<uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

	<application
		android:name=".FerrioApplication"
		android:allowBackup="true"
		android:dataExtractionRules="@xml/data_extraction_rules"
		android:fullBackupContent="@xml/backup_descriptor"
		android:icon="@mipmap/ic_launcher"
		android:label="@string/app_name"
		android:networkSecurityConfig="@xml/network_security_config"
		android:theme="@style/AppTheme"
		tools:targetApi="s">
		<meta-data
			android:name="com.google.android.gms.version"
			android:value="@integer/google_play_services_version" />
		<meta-data
			android:name="com.google.android.gms.ads.APPLICATION_ID"
			android:value="@string/admob_app_id" />

		<activity
			android:name=".activity.LoginActivity"
			android:exported="true">
			<intent-filter>
				<action android:name="android.intent.action.MAIN" />

				<category android:name="android.intent.category.LAUNCHER" />
			</intent-filter>
		</activity>
		<activity
			android:name=".activity.MainActivity" />
		<activity
			android:name=".activity.SuggestionActivity"
			android:exported="false" />
		<activity
			android:name=".activity.TabbedListActivity"
			android:exported="false" />
		<activity
			android:name=".activity.DayActivity" />
		<activity
			android:name=".activity.HolidayActivity"
			android:windowSoftInputMode="stateVisible|adjustResize" />
		<activity
			android:name=".widget.WidgetConfigActivity"
			android:exported="false" />
		<activity
			android:name=".activity.SettingsActivity"
			android:label="@string/menu_main_settings">
			<meta-data
				android:name="android.support.PARENT_ACTIVITY"
				android:value="eu.andret.kalendarzswiatnietypowych.activity.MainActivity" />
		</activity>

		<provider
			android:name="androidx.core.content.FileProvider"
			android:authorities="${applicationId}.fileprovider"
			android:exported="false"
			android:grantUriPermissions="true">
			<meta-data
				android:name="android.support.FILE_PROVIDER_PATHS"
				android:resource="@xml/file_paths" />
		</provider>

		<receiver
			android:name=".widget.WidgetProvider"
			android:exported="true">
			<intent-filter>
				<action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
				<action android:name="ACTION_AUTO_UPDATE_WIDGET" />
				<action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
			</intent-filter>

			<meta-data
				android:name="android.appwidget.provider"
				android:resource="@xml/widget_provider" />
		</receiver>

		<receiver
			android:name=".widget.TransparentWidgetProvider"
			android:exported="true"
			android:label="Ferrio (Transparent)">
			<intent-filter>
				<action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
				<action android:name="ACTION_AUTO_UPDATE_WIDGET" />
				<action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
			</intent-filter>

			<meta-data
				android:name="android.appwidget.provider"
				android:resource="@xml/widget_provider_transparent" />
		</receiver>
	</application>

</manifest>
