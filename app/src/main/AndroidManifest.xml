<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="eu.andret.kalendarzswiatnietypowych">

    <!--
    a.b.c.de
    a - zmiana rdzenia, calkowita zmiana kodu, pisanie od 0
    b - mocna optymalizacja i duze poprawki
    c - nowo dodane funkcje
	d - zakodowana data (mmdd)
	e - drobne zmiany i poprawki
    -->

    <uses-permission
        android:name="android.permission.INTERNET" />
    <uses-permission
        android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission
        android:name="android.permission.WAKE_LOCK" />
    <!--
        <uses-permission
        android:name="com.android.vending.BILLING" />



    -->

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.AppCompat.DayNight.DarkActionBar"
        android:fullBackupContent="@xml/backup_descriptor"
        tools:ignore="GoogleAppIndexingWarning">
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3410450408196791~3872850665" />

        <service
            android:name=".NotificationService" />

        <activity
            android:name=".activities.MainActivity"
            android:screenOrientation="sensorPortrait" >
            <intent-filter>
                <action
                    android:name="android.intent.action.MAIN" />

                <category
                    android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.google.android.gms.ads.AdActivity"
            android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|uiMode|screenSize|smallestScreenSize" />
        <activity
            android:name=".activities.DayActivity"
            android:screenOrientation="sensorPortrait" >
        </activity>
        <activity
            android:name=".activities.FavouriteActivity"
            android:screenOrientation="sensorPortrait" >
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="eu.andret.kalendarzswiatnietypowych.activities.MainActivity" />
        </activity>

        <receiver
            android:name="eu.andret.kalendarzswiatnietypowych.MyWidgetProvider" >
            <intent-filter>
                <action
                    android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action
                    android:name="eu.andret.kalendarzswiatnietypowych.CLICK_MY_BUTTON" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/my_widget_provider" />
        </receiver>

        <activity
            android:name=".activities.SettingsActivity"
            android:label="@string/settings"
            android:screenOrientation="sensorPortrait" >
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="eu.andret.kalendarzswiatnietypowych.activities.MainActivity" />
        </activity>
        <!--
         <activity
            android:name="eu.andret.kalendarzswiatnietypowych.activities.WidgetConfigurationActivity"
            android:label="@string/settings"
            android:theme="@android:style/Theme.Dialog" >
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>



        -->
        <activity
            android:name=".activities.LanguageActivity"
            android:label="@string/title_activity_language" >
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="eu.andret.kalendarzswiatnietypowych.activities.MainActivity" />
        </activity>
        <activity
            android:name="eu.andret.kalendarzswiatnietypowych.activities.SurveyActivity"
            android:label="@string/title_activity_survey" >
        </activity>
    </application>

</manifest>